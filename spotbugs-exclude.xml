<?xml version="1.0" encoding="UTF-8"?>
<!-- SpotBugs Exclusion Filter -->
<!-- Excludes false positives generated by Lombok annotations on JPA entities and DTOs -->
<!-- EI_EXPOSE_REP and EI_EXPOSE_REP2 are expected in JPA/Spring managed objects -->
<FindBugsFilter>

    <!-- Exclude EI_EXPOSE_REP warnings from JPA model classes -->
    <!-- JPA entities require mutable fields for Hibernate to manage object relationships -->
    <Match>
        <Package name="com.rakshan.codereview.model"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP warnings from DTO classes -->
    <!-- DTOs are data carriers managed by Spring and Jackson serialisation -->
    <Match>
        <Package name="com.rakshan.codereview.dto"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 from Spring-managed controller constructors -->
    <!-- Spring dependency injection manages the lifecycle of injected services -->
    <Match>
        <Package name="com.rakshan.codereview.controller"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude EI_EXPOSE_REP2 from Spring-managed config constructors -->
    <!-- Spring Security filters are managed by the framework -->
    <Match>
        <Package name="com.rakshan.codereview.config"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude CT_CONSTRUCTOR_THROW from JwtTokenProvider -->
    <!-- Key generation via Keys.hmacShaKeyFor is safe; Spring manages the component lifecycle -->
    <Match>
        <Class name="com.rakshan.codereview.config.JwtTokenProvider"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

</FindBugsFilter>
